// Helper function to get favicon
function getFavicon(url: string, name: string): string {
  const domain = getDomain(url);

  // Special cases for sites where Google favicon doesn't work well
  const specialFavicons: Record<string, string> = {
    "chatgpt.com":
      "https://cdn.oaistatic.com/_next/static/media/favicon-32x32.6e956b52.png",
    "chat.inceptionlabs.ai": "https://chat.inceptionlabs.ai/favicon.ico",
    "app.roocode.com":
      "https://ui-avatars.com/api/?name=Roo&background=7c3aed&color=fff&size=128&format=png",
    "app.kilocode.ai":
      "https://ui-avatars.com/api/?name=KC&background=10b981&color=fff&size=128&format=png",
    "create.wan.video":
      "https://ui-avatars.com/api/?name=Wan&background=f59e0b&color=fff&size=128&format=png",
    "tongyi.com": "https://cdn.simpleicons.org/alibabacloud/FF6A00",
    "chat.sensetime.com":
      "https://ui-avatars.com/api/?name=SN&background=1e40af&color=fff&size=128&format=png",
  };

  if (specialFavicons[domain]) {
    return specialFavicons[domain];
  }

  // Fallback to Google's favicon service
  return `https://www.google.com/s2/favicons?domain=${domain}&sz=128`;
}

// Process all categories to add domain and favicon
const processedCategories = Object.fromEntries(
  Object.entries(aiCategories).map(([key, category]) => [
    key,
    {
      ...category,
      items: category.items.map((item) => ({
        ...item,
        domain: getDomain(item.url),
        faviconUrl: getFavicon(item.url, item.name),
      })),
    },
  ]),
);

// Calculate totals
const totalItems = Object.values(aiCategories).reduce(
  (sum, cat) => sum + cat.items.length,
  0,
);
const categoryKeys = Object.keys(aiCategories);
---

<BaseLayout title="AI Models 🤖">
  <div class="ai-container">
    <div class="ai-header">
      <div class="header-content">
        <h1>AI Models 🤖</h1>
        <p>
          Explore the cutting-edge AI tools I use and experiment with. Select a
          category below to browse different types of AI services.
        </p>
      </div>
      <div class="header-decoration">
        <div class="decoration-item"></div>
        <div class="decoration-item"></div>
        <div class="decoration-item"></div>
      </div>
    </div>

    <!-- Category Filter Buttons -->
    <div class="category-buttons">
      {
        Object.entries(processedCategories).map(([key, category]) => (
          <button
            class="category-btn"
            data-category={key}
            data-active={key === "llm" ? "true" : "false"}
          >
            <span class="btn-icon">{category.icon}</span>
            <span class="btn-text">{category.name}</span>
            <span class="btn-count">{category.items.length}</span>
          </button>
        ))
      }
    </div>

    <!-- Category Sections -->
    {
      Object.entries(processedCategories).map(([key, category]) => (
        <div
          class="category-section"
          data-section={key}
          style={key === "llm" ? "" : "display: none;"}
        >
          <div class="section-header">
            <h2>
              {category.icon} {category.name}
            </h2>
            <p>{category.description}</p>
          </div>

          <div class="ai-grid">
            {category.items.map((ai) => (
              <a href={ai.url} target="_blank" rel="noopener" class="ai-card">
                <div class="ai-icon">
                  <img
                    src={ai.faviconUrl}
                    alt={`${ai.name} icon`}
                    class="favicon"
                    onerror={`this.src='https://ui-avatars.com/api/?name=${encodeURIComponent(ai.name)}&background=637cce&color=fff&size=64&format=png'`}
                  />
                </div>
                <div class="ai-content">
                  <div class="ai-meta">
                    <span class="ai-category">{ai.subcategory}</span>
                  </div>
                  <h3>{ai.name}</h3>
                  <p class="ai-desc">{ai.domain}</p>
                  <div class="ai-link">
                    Try AI <i class="fas fa-arrow-right" />
                  </div>
                </div>
              </a>
            ))}
          </div>
        </div>
      ))
    }

    <div class="ai-footer">
      <div class="ai-stats">
        <h3>AI Usage Stats</h3>
        <div class="stats-container">
          <div class="stat-item">
            <span class="stat-number">{totalItems}</span>
            <span class="stat-label">AI Tools</span>
          </div>
          <div class="stat-item">
            <span class="stat-number">{categoryKeys.length}</span>
            <span class="stat-label">Categories</span>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Font Awesome for icons -->
  <link
    rel="stylesheet"
    href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css"
  />

  <script>
    document.addEventListener("DOMContentLoaded", () => {
      const buttons = document.querySelectorAll<HTMLElement>(".category-btn");
      const sections =
        document.querySelectorAll<HTMLElement>(".category-section");

      buttons.forEach((button) => {
        button.addEventListener("click", () => {
          const category = button.getAttribute("data-category");

          // Update button states
          buttons.forEach((btn) => btn.setAttribute("data-active", "false"));
          button.setAttribute("data-active", "true");

          // Show/hide sections
          sections.forEach((section) => {
            if (section.getAttribute("data-section") === category) {
              section.style.display = "block";
            } else {
              section.style.display = "none";
            }
          });
        });
      });
    });
  </script>

  <style>
    :root {
      --primary-color: #637cce;
      --secondary-color: #8da7f0;
      --accent-color: #ff7e67;
      --dark-color: #2c3e50;
      --light-color: #f8f9fa;
      --text-color: #333;
      --card-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
      --hover-shadow: 0 15px 35px rgba(0, 0, 0, 0.15);
    }

    .ai-container {
      max-width: 1400px;
      margin: 0 auto;
      padding: 2rem;
      background: linear-gradient(135deg, #f5f7ff 0%, #e8ecff 100%);
      min-height: 100vh;
      border-radius: 20px;
      box-shadow: 0 5px 20px rgba(0, 0, 0, 0.05);
    }

    .ai-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 2rem;
      position: relative;
    }

    .header-content {
      flex: 2;
    }

    .ai-header h1 {
      font-size: 3rem;
      color: var(--dark-color);
      margin-bottom: 1rem;
      position: relative;
      display: inline-block;
    }

    .ai-header h1::after {
      content: "";
      position: absolute;
      bottom: -10px;
      left: 0;
      width: 80px;
      height: 4px;
      background: linear-gradient(
        90deg,
        var(--primary-color),
        var(--secondary-color)
      );
      border-radius: 2px;
    }

    .ai-header p {
      color: var(--text-color);
      max-width: 700px;
      margin-top: 1.5rem;
      line-height: 1.6;
    }

    .header-decoration {
      flex: 1;
      display: flex;
      justify-content: flex-end;
      align-items: center;
      gap: 15px;
    }

    .decoration-item {
      width: 40px;
      height: 40px;
      border-radius: 50%;
      background: linear-gradient(
        135deg,
        var(--primary-color),
        var(--secondary-color)
      );
      opacity: 0.7;
    }

    .decoration-item:nth-child(2) {
      width: 60px;
      height: 60px;
      background: linear-gradient(135deg, var(--accent-color), #ff9e80);
    }

    .decoration-item:nth-child(3) {
      width: 30px;
      height: 30px;
      background: linear-gradient(135deg, #16a085, #1abc9c);
    }

    /* Category Filter Buttons */
    .category-buttons {
      display: flex;
      flex-wrap: nowrap;
      gap: 0.5rem;
      margin-bottom: 2rem;
      justify-content: center;
      padding: 0.5rem;
      background: rgba(255, 255, 255, 0.7);
      border-radius: 50px;
      backdrop-filter: blur(10px);
      box-shadow: 0 2px 12px rgba(0, 0, 0, 0.08);
    }

    .category-btn {
      display: flex;
      align-items: center;
      gap: 0.4rem;
      padding: 0.5rem 1rem;
      background: transparent;
      border: none;
      border-radius: 50px;
      cursor: pointer;
      transition: all 0.25s ease;
      font-family: inherit;
      white-space: nowrap;
    }

    .category-btn:hover {
      background: rgba(99, 124, 206, 0.1);
    }

    .category-btn[data-active="true"] {
      background: var(--primary-color);
      color: white;
      box-shadow: 0 2px 8px rgba(99, 124, 206, 0.4);
    }

    .category-btn[data-active="true"] .btn-count {
      background: rgba(255, 255, 255, 0.25);
      color: white;
    }

    .btn-icon {
      font-size: 1rem;
    }

    .btn-text {
      font-size: 0.85rem;
      font-weight: 600;
    }

    .btn-count {
      background: rgba(99, 124, 206, 0.15);
      color: var(--primary-color);
      padding: 0.15rem 0.5rem;
