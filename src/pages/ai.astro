// Favicon helper — tries direct favicon first, falls back to DuckDuckGo
function getFavicon(url: string): string {
  const domain = getDomain(url);
  const specialFavicons: Record<string, string> = {
    "chatgpt.com": "https://cdn.oaistatic.com/_next/static/media/favicon-32x32.6e956b52.png",
    "chat.inceptionlabs.ai": "https://chat.inceptionlabs.ai/favicon.ico",
    "app.roocode.com": "https://ui-avatars.com/api/?name=Roo&background=7c3aed&color=fff&size=128&format=png",
    "app.kilocode.ai": "https://ui-avatars.com/api/?name=KC&background=10b981&color=fff&size=128&format=png",
    "create.wan.video": "https://ui-avatars.com/api/?name=Wan&background=f59e0b&color=fff&size=128&format=png",
    "tongyi.com": "https://cdn.simpleicons.org/alibabacloud/FF6A00",
    "chat.sensetime.com": "https://ui-avatars.com/api/?name=SN&background=1e40af&color=fff&size=128&format=png",
    "copilot.microsoft.com": "https://copilot.microsoft.com/favicon.ico",
    "grok.com": "https://grok.com/favicon.ico",
    "aistudio.google.com": "https://aistudio.google.com/favicon.ico",
    "ernie.baidu.com": "https://ernie.baidu.com/favicon.ico",
    "chat.qwen.ai": "https://chat.qwen.ai/favicon.ico",
    "chat.z.ai": "https://chat.z.ai/favicon.ico",
    "chat.deepseek.com": "https://chat.deepseek.com/favicon.ico",
    "longcat.chat": "https://longcat.chat/favicon.ico",
    "www.kimi.com": "https://www.kimi.com/favicon.ico",
    "manus.im": "https://manus.im/favicon.ico",
    "venice.ai": "https://venice.ai/favicon.ico",
    "playground.liquid.ai": "https://playground.liquid.ai/favicon.ico",
    "chat.minimax.io": "https://chat.minimax.io/favicon.ico",
    "www.minimaxi.com": "https://www.minimaxi.com/favicon.ico",
  };
  if (specialFavicons[domain]) return specialFavicons[domain];
  // DuckDuckGo icons — more reliable than Google's favicon service
  return `https://icons.duckduckgo.com/ip3/${domain}.ico`;
}

// Process data
const processedCategories = Object.fromEntries(
  Object.entries(aiCategories).map(([key, category]) => [
    key,
    {
      ...category,
      icon: categoryIcons[key],
      color: categoryColors[key],
      items: category.items.map((item) => ({
        ...item,
        domain: getDomain(item.url),
        faviconUrl: getFavicon(item.url),
      })),
    },
  ])
);

// Get unique subcategories per category
const subcategories: Record<string, string[]> = {};
for (const [key, cat] of Object.entries(aiCategories)) {
  subcategories[key] = [...new Set(cat.items.map((i) => i.subcategory))];
}

const totalItems = Object.values(aiCategories).reduce((sum, cat) => sum + cat.items.length, 0);
const categoryKeys = Object.keys(aiCategories);

// JSON data for client-side search
const jsonData = JSON.stringify(
  Object.entries(processedCategories).map(([key, cat]) => ({
    key,
    name: cat.name,
    color: cat.color,
    items: cat.items,
  }))
);
---

<BaseLayout title="AI Models">
  <div class="ai-page">
    <!-- Hero section -->
    <header class="ai-hero">
      <div class="hero-badge">
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2a4 4 0 0 1 4 4c0 1.95-1.4 3.58-3.25 3.93L12 22"/><circle cx="12" cy="6" r="1"/></svg>
        <span>{totalItems} tools curated</span>
      </div>
      <h1 class="ai-title">AI Toolkit</h1>
      <p class="ai-subtitle">A curated collection of AI tools I use and experiment with. Search, filter, and explore.</p>

      <!-- Search bar -->
      <div class="search-wrapper">
        <svg class="search-icon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
        <input type="text" id="search-input" class="search-input" placeholder="Search AI tools..." autocomplete="off" />
        <kbd class="search-kbd">/</kbd>
      </div>
    </header>

    <!-- Category tabs -->
    <nav class="category-tabs" role="tablist">
      {
        Object.entries(processedCategories).map(([key, category]) => (
          <button
            class="category-tab"
            data-category={key}
            data-active={key === "llm" ? "true" : "false"}
            role="tab"
            aria-selected={key === "llm" ? "true" : "false"}
            style={`--tab-color: ${category.color}`}
          >
            <span class="tab-icon" set:html={category.icon} />
            <span class="tab-name">{category.name}</span>
            <span class="tab-count">{category.items.length}</span>
          </button>
        ))
      }
    </nav>

    <!-- Subcategory filters -->
    {
      Object.entries(subcategories).map(([key, subs]) => (
        <div class="sub-filters" data-subfilters={key} style={key === "llm" ? "" : "display: none;"}>
          <button class="sub-pill active" data-sub="all">All</button>
          {subs.map((sub) => (
            <button class="sub-pill" data-sub={sub}>{sub}</button>
          ))}
        </div>
      ))
    }

    <!-- Results count -->
    <div class="results-bar">
      <span id="results-count" class="results-count"></span>
    </div>

    <!-- Category sections -->
    {
      Object.entries(processedCategories).map(([key, category]) => (
        <section
          class="ai-grid-section"
          data-section={key}
          style={key === "llm" ? "" : "display: none;"}
          role="tabpanel"
        >
          <div class="ai-grid">
            {category.items.map((ai, index) => (
              <a
                href={ai.url}
                target="_blank"
                rel="noopener noreferrer"
                class="ai-card"
                data-name={ai.name.toLowerCase()}
                data-subcategory={ai.subcategory}
                style={`animation-delay: ${index * 30}ms; --card-accent: ${category.color}`}
              >
                <div class="card-top">
                  <img
                    src={ai.faviconUrl}
                    alt=""
                    class="card-favicon"
                    loading="lazy"
                    onerror={`this.src='https://ui-avatars.com/api/?name=${encodeURIComponent(ai.name)}&background=e2e8f0&color=475569&size=64&format=png'`}
                  />
                  <span class="card-subcategory">{ai.subcategory}</span>
                </div>
                <div class="card-body">
                  <h3 class="card-name">{ai.name}</h3>
                  <p class="card-domain">{ai.domain}</p>
                </div>
                <div class="card-action">
                  <span>Visit</span>
                  <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="7" y1="17" x2="17" y2="7"/><polyline points="7 7 17 7 17 17"/></svg>
                </div>
              </a>
            ))}
          </div>
        </section>
      ))
    }

    <!-- No results message -->
    <div class="no-results" id="no-results" style="display: none;">
      <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/><line x1="8" y1="11" x2="14" y2="11"/></svg>
      <p>No tools match your search.</p>
      <span>Try a different keyword or clear your search.</span>
    </div>

    <!-- Footer stats -->
    <footer class="ai-footer">
      <div class="footer-stats">
        {
          Object.entries(processedCategories).map(([key, category]) => (
            <div class="footer-stat">
              <span class="footer-stat-num" style={`color: ${category.color}`}>{category.items.length}</span>
              <span class="footer-stat-label">{category.name}</span>
            </div>
          ))
        }
      </div>
    </footer>
  </div>

  <script define:vars={{ jsonData }}>
    const categoriesData = JSON.parse(jsonData);

    document.addEventListener("DOMContentLoaded", () => {
      const searchInput = document.getElementById("search-input");
      const resultsCount = document.getElementById("results-count");
      const noResults = document.getElementById("no-results");
      const tabs = document.querySelectorAll(".category-tab");
      const sections = document.querySelectorAll(".ai-grid-section");
      const subFilterGroups = document.querySelectorAll(".sub-filters");

      let activeCategory = "llm";
      let activeSubcategory = "all";

      // Update results count
      function updateResultsCount() {
        const visibleCards = document.querySelectorAll(
          `.ai-grid-section[data-section="${activeCategory}"] .ai-card:not(.hidden)`
        );
        const total = document.querySelectorAll(
          `.ai-grid-section[data-section="${activeCategory}"] .ai-card`
        );
        const query = searchInput.value.trim();

        if (query || activeSubcategory !== "all") {
          resultsCount.textContent = `${visibleCards.length} of ${total.length} tools`;
        } else {
          resultsCount.textContent = `${total.length} tools`;
        }

        noResults.style.display = visibleCards.length === 0 ? "flex" : "none";
      }

      // Filter cards
      function filterCards() {
        const query = searchInput.value.toLowerCase().trim();
        const currentSection = document.querySelector(
          `.ai-grid-section[data-section="${activeCategory}"]`
        );
        const cards = currentSection.querySelectorAll(".ai-card");

        cards.forEach((card) => {
          const name = card.dataset.name;
          const sub = card.dataset.subcategory;
          const matchesSearch =
            !query || name.includes(query) || sub.toLowerCase().includes(query);
          const matchesSub =
            activeSubcategory === "all" || sub === activeSubcategory;

          if (matchesSearch && matchesSub) {
            card.classList.remove("hidden");
            card.style.display = "";
          } else {
            card.classList.add("hidden");
            card.style.display = "none";
          }
        });

        updateResultsCount();
      }

      // Category tab switching
      tabs.forEach((tab) => {
        tab.addEventListener("click", () => {
          const category = tab.dataset.category;
          activeCategory = category;
          activeSubcategory = "all";

          tabs.forEach((t) => {
            t.dataset.active = "false";
            t.setAttribute("aria-selected", "false");
          });
          tab.dataset.active = "true";
          tab.setAttribute("aria-selected", "true");

          sections.forEach((section) => {
            section.style.display =
              section.dataset.section === category ? "" : "none";
          });

          subFilterGroups.forEach((group) => {
            group.style.display =
              group.dataset.subfilters === category ? "" : "none";
          });

          // Reset subcategory pills
          document
            .querySelectorAll(`[data-subfilters="${category}"] .sub-pill`)
            .forEach((pill) => {
              pill.classList.toggle("active", pill.dataset.sub === "all");
            });

          filterCards();
        });
      });

      // Subcategory pill filtering
      document.addEventListener("click", (e) => {
        const pill = e.target.closest(".sub-pill");
        if (!pill) return;

        const parent = pill.closest(".sub-filters");
        if (parent.dataset.subfilters !== activeCategory) return;

        parent.querySelectorAll(".sub-pill").forEach((p) => p.classList.remove("active"));
        pill.classList.add("active");
        activeSubcategory = pill.dataset.sub;
        filterCards();
      });

      // Search input
      searchInput.addEventListener("input", () => {
        filterCards();
      });

      // Keyboard shortcut: "/" to focus search
      document.addEventListener("keydown", (e) => {
        if (
          e.key === "/" &&
          document.activeElement !== searchInput &&
          !e.ctrlKey &&
          !e.metaKey
        ) {
          e.preventDefault();
          searchInput.focus();
        }
        if (e.key === "Escape" && document.activeElement === searchInput) {
          searchInput.value = "";
          searchInput.blur();
          filterCards();
        }
      });

      // Initial count
      updateResultsCount();
    });
  </script>

