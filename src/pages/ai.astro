// Function to extract domain from URL
function getDomain(url: string): string {
  try {
    const domain = new URL(url).hostname;
    return domain.startsWith("www.") ? domain.substring(4) : domain;
  } catch (e) {
    return url.replace(/^https?:\/\//, "").replace(/\/$/, "");
  }
}

