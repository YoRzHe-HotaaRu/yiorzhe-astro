---
// src/pages/apps.astro
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="My Web Apps 🌏">
  <div class="apps-container">
    <div class="apps-header">
      <div class="header-content">
        <h1>My Web Apps 🌏</h1>
        <p>
          Explore my collection of web applications. Choose a category below to
          discover projects ranging from full-featured applications to handy
          utility tools.
        </p>
      </div>
      <div class="header-decoration">
        <div class="decoration-item"></div>
        <div class="decoration-item"></div>
        <div class="decoration-item"></div>
      </div>
    </div>

    <!-- Navigation Cards -->
    <div class="nav-grid">
      <!-- Featured Projects Card -->
      <a href="/apps/featured" class="nav-card featured-nav">
        <div class="nav-icon">
          <i class="fas fa-star"></i>
        </div>
        <div class="nav-content">
          <h2>Featured Projects</h2>
          <p>
            Major applications and full-featured projects including A.K.A.R.I,
            YuGiDex, FolioS, and MyGal.
          </p>
          <div class="nav-arrow">
            Explore <i class="fas fa-arrow-right"></i>
          </div>
        </div>
        <div class="nav-preview">
          <div class="preview-item">
            <img src="/assets/apps/AKARI.png" alt="A.K.A.R.I" />
          </div>
          <div class="preview-item">
            <img src="/assets/apps/Yugidex.png" alt="YuGiDex" />
          </div>
          <div class="preview-item">
            <img src="/assets/apps/FolioS.png" alt="FolioS" />
          </div>
          <div class="preview-item">
            <img src="/assets/apps/mygal.png" alt="MyGal" />
          </div>
        </div>
      </a>

      <!-- Simple Apps Card -->
      <a href="/apps/simple" class="nav-card simple-nav">
        <div class="nav-icon">
          <i class="fas fa-tools"></i>
        </div>
        <div class="nav-content">
          <h2>Simple Apps</h2>
          <p>
            Quick utility tools and handy mini-applications including PDF Merger,
            Password Generator, and QR Generator.
          </p>
          <div class="nav-arrow">
            Explore <i class="fas fa-arrow-right"></i>
          </div>
        </div>
        <div class="nav-preview">
          <div class="preview-item">
            <img src="/assets/apps/pdfMerger.jpg" alt="PDF Merger" />
          </div>
          <div class="preview-item">
            <img src="/assets/apps/passwordGen.jpg" alt="Password Generator" />
          </div>
          <div class="preview-item">
            <img src="/assets/apps/qrGenerator.jpg" alt="QR Generator" />
          </div>
        </div>
      </a>
    </div>

    <div class="apps-footer">
      <div class="tech-stack">
        <h3>Tech Stack</h3>
        <div class="tech-icons">
          <div class="tech-icon" title="HTML5">
            <i class="fab fa-html5"></i>
          </div>
          <div class="tech-icon" title="CSS3">
            <i class="fab fa-css3-alt"></i>
          </div>
          <div class="tech-icon" title="JavaScript">
            <i class="fab fa-js-square"></i>
          </div>
          <div class="tech-icon" title="React">
            <i class="fab fa-react"></i>
          </div>
          <div class="tech-icon" title="Node.js">
            <i class="fab fa-node-js"></i>
          </div>
          <div class="tech-icon" title="Python">
            <i class="fab fa-python"></i>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Font Awesome for icons -->
  <link
    rel="stylesheet"
    href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css"
  />

  <style>
    :root {
      --primary-color: #637cce;
      --secondary-color: #8da7f0;
      --accent-color: #ff7e67;
      --dark-color: #2c3e50;
      --light-color: #f8f9fa;
      --text-color: #333;
      --card-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
      --hover-shadow: 0 20px 40px rgba(0, 0, 0, 0.15);
      --featured-gradient: linear-gradient(135deg, #ffd700 0%, #ffed4e 100%);
      --simple-gradient: linear-gradient(135deg, #74b9ff 0%, #0984e3 100%);
    }

    .apps-container {
      max-width: 1200px;
      margin: 0 auto;
      padding: 2rem;
      background: linear-gradient(135deg, #f5f7ff 0%, #e8ecff 100%);
      min-height: 100vh;
      border-radius: 20px;
      box-shadow: 0 5px 20px rgba(0, 0, 0, 0.05);
    }

    .apps-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 3rem;
      position: relative;
    }

    .header-content {
      flex: 2;
    }

    .apps-header h1 {
      font-size: 3rem;
      color: var(--dark-color);
      margin-bottom: 1rem;
      position: relative;
      display: inline-block;
    }

    .apps-header h1::after {
      content: "";
      position: absolute;
      bottom: -10px;
      left: 0;
      width: 80px;
      height: 4px;
      background: linear-gradient(
        90deg,
        var(--primary-color),
        var(--secondary-color)
      );
      border-radius: 2px;
    }

    .apps-header p {
      color: var(--text-color);
      max-width: 700px;
      margin-top: 1.5rem;
      line-height: 1.6;
    }

    .header-decoration {
      flex: 1;
      display: flex;
      justify-content: flex-end;
      align-items: center;
      gap: 15px;
    }

    .decoration-item {
      width: 40px;
      height: 40px;
      border-radius: 50%;
      background: linear-gradient(
        135deg,
        var(--primary-color),
        var(--secondary-color)
      );
      opacity: 0.7;
    }

    .decoration-item:nth-child(2) {
      width: 60px;
      height: 60px;
      background: linear-gradient(135deg, var(--accent-color), #ff9e80);
    }

    .decoration-item:nth-child(3) {
      width: 30px;
      height: 30px;
      background: linear-gradient(135deg, #16a085, #1abc9c);
    }

    /* Navigation Grid */
    .nav-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(450px, 1fr));
      gap: 2rem;
      margin-bottom: 3rem;
    }

    .nav-card {
      background: white;
      border-radius: 20px;
      padding: 2rem;
      box-shadow: var(--card-shadow);
      transition:
        transform 0.3s ease,
        box-shadow 0.3s ease;
      display: flex;
      flex-direction: column;
      text-decoration: none;
      color: inherit;
      position: relative;
      overflow: hidden;
    }

    .nav-card::before {
      content: "";
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      height: 5px;
    }

    .featured-nav::before {
      background: var(--featured-gradient);
    }

    .simple-nav::before {
      background: var(--simple-gradient);
    }

    .nav-card:hover {
      transform: translateY(-10px);
      box-shadow: var(--hover-shadow);
    }

    .nav-icon {
      width: 70px;
      height: 70px;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 1.8rem;
      margin-bottom: 1.5rem;
    }

    .featured-nav .nav-icon {
      background: var(--featured-gradient);
      color: #2c3e50;
      box-shadow: 0 4px 15px rgba(255, 215, 0, 0.4);
    }

    .simple-nav .nav-icon {
      background: var(--simple-gradient);
      color: white;
      box-shadow: 0 4px 15px rgba(116, 185, 255, 0.4);
    }

    .nav-content h2 {
      font-size: 1.8rem;
      color: var(--dark-color);
      margin-bottom: 0.75rem;
    }

    .nav-content p {
      color: #666;
      line-height: 1.6;
      margin-bottom: 1.5rem;
    }

    .nav-arrow {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      color: var(--primary-color);
      font-weight: 600;
      transition: gap 0.3s ease;
    }

    .nav-card:hover .nav-arrow {
      gap: 0.75rem;
    }

    .nav-preview {
      display: flex;
      gap: 0.5rem;
      margin-top: 1.5rem;
      padding-top: 1.5rem;
      border-top: 1px solid #eee;
    }

    .preview-item {
      flex: 1;
      height: 80px;
      border-radius: 8px;
      overflow: hidden;
      opacity: 0.7;
      transition: opacity 0.3s ease;
    }

    .nav-card:hover .preview-item {
      opacity: 1;
    }

    .preview-item img {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }

    .apps-footer {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 2rem;
      margin-top: 2rem;
    }

    .tech-stack {
      width: 100%;
      background: white;
      padding: 1.5rem;
      border-radius: 16px;
      box-shadow: var(--card-shadow);
      text-align: center;
    }

    .tech-stack h3 {
      font-size: 1.5rem;
      color: var(--dark-color);
      margin-bottom: 1.5rem;
    }

    .tech-icons {
      display: flex;
      justify-content: center;
      flex-wrap: wrap;
      gap: 1.5rem;
    }

    .tech-icon {
      width: 50px;
      height: 50px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 1.8rem;
      color: var(--dark-color);
      transition:
        transform 0.3s ease,
        color 0.3s ease;
    }

    .tech-icon:hover {
      transform: translateY(-5px);
      color: var(--primary-color);
    }

    .tech-icon:nth-child(1) {
      color: #e34c26;
    }
    .tech-icon:nth-child(2) {
      color: #1572b6;
    }
    .tech-icon:nth-child(3) {
      color: #f7df1e;
    }
    .tech-icon:nth-child(4) {
      color: #61dafb;
    }
    .tech-icon:nth-child(5) {
      color: #339933;
    }
    .tech-icon:nth-child(6) {
      color: #3776ab;
    }

    /* Responsive adjustments */
    @media (max-width: 992px) {
      .apps-header {
        flex-direction: column;
        align-items: flex-start;
      }

      .header-decoration {
        margin-top: 1rem;
        justify-content: flex-start;
      }

      .nav-grid {
        grid-template-columns: 1fr;
      }
    }

    @media (max-width: 768px) {
      .apps-container {
        padding: 1.5rem;
      }

      .apps-header h1 {
        font-size: 2.5rem;
      }

      .nav-card {
        padding: 1.5rem;
      }

      .nav-content h2 {
        font-size: 1.5rem;
      }

      .tech-icons {
        gap: 1rem;
      }

      .tech-icon {
        width: 40px;
        height: 40px;
        font-size: 1.5rem;
      }
    }

    @media (max-width: 480px) {
      .apps-header h1 {
        font-size: 2rem;
      }

      .nav-icon {
        width: 60px;
        height: 60px;
        font-size: 1.5rem;
      }

      .preview-item {
        height: 60px;
      }
    }
  </style>
</BaseLayout>
