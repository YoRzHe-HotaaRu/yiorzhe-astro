---
// src/pages/apps/featured.astro
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout title="Featured Projects ⭐">
  <div class="apps-container">
    <div class="page-header">
      <a href="/apps" class="back-link">
        <i class="fas fa-arrow-left"></i> Back to Apps
      </a>
      <div class="header-content">
        <h1>Featured Projects</h1>
        <p>Major applications and full-featured projects</p>
      </div>
    </div>

    <div class="apps-grid">
      <!-- App 1: A.K.A.R.I -->
      <a
        href="https://vulkan747.pythonanywhere.com/"
        target="_blank"
        rel="noopener"
        class="app-card"
      >
        <div class="app-image">
          <img src="/assets/apps/AKARI.png" alt="A.K.A.R.I" />
          <div class="app-overlay">
            <div class="app-icon">
              <i class="fas fa-robot"></i>
            </div>
          </div>
        </div>
        <div class="app-content">
          <div class="app-meta">
            <span class="app-category">AI Assistant</span>
            <span class="app-status live">Live</span>
          </div>
          <h3>A.K.A.R.I</h3>
          <p class="app-desc">
            Advanced Knowledgeable Assembly Rig Instructor – a sweet, slightly
            shy, and super knowledgeable virtual assistant designed to guide
            absolute beginners in building their own computers 💻💖
          </p>
          <div class="app-link">
            View App <i class="fas fa-arrow-right"></i>
          </div>
        </div>
      </a>

      <!-- App 2: YuGiDex -->
      <a
        href="https://yugidex-enn.pages.dev/"
        target="_blank"
        rel="noopener"
        class="app-card"
      >
        <div class="app-image">
          <img src="/assets/apps/Yugidex.png" alt="YuGiDex" />
          <div class="app-overlay">
            <div class="app-icon">
              <i class="fa-solid fa-dragon"></i>
            </div>
          </div>
        </div>
        <div class="app-content">
          <div class="app-meta">
            <span class="app-category">Database</span>
            <span class="app-status live">Live</span>
          </div>
          <h3>YuGiDex</h3>
          <p class="app-desc">
            YuGiDex is a modern, interactive web application designed as a
            comprehensive database for Yu-Gi-Oh!
          </p>
          <div class="app-link">
            View App <i class="fas fa-arrow-right"></i>
          </div>
        </div>
      </a>

      <!-- App 3: FolioS -->
      <a
        href="https://hunterxv.pythonanywhere.com/"
        target="_blank"
        rel="noopener"
        class="app-card"
      >
        <div class="app-image">
          <img src="/assets/apps/FolioS.png" alt="FolioS" />
          <div class="app-overlay">
            <div class="app-icon">
              <i class="fa-solid fa-note-sticky"></i>
            </div>
          </div>
        </div>
        <div class="app-content">
          <div class="app-meta">
            <span class="app-category">Productivity</span>
            <span class="app-status beta">Beta</span>
          </div>
          <h3>FolioS</h3>
          <p class="app-desc">
            FolioS is a simple digital note taking app that can be access via
            your laptop, PC or mobile. Anywhere, anytime.
          </p>
          <div class="app-link">
            View App <i class="fas fa-arrow-right"></i>
          </div>
        </div>
      </a>

      <!-- App 4: MyGal -->
      <a
        href="https://mygal-six.vercel.app"
        target="_blank"
        rel="noopener"
        class="app-card"
      >
        <div class="app-image">
          <img src="/assets/apps/mygal.png" alt="MyGal" />
          <div class="app-overlay">
            <div class="app-icon">
              <i class="fa-solid fa-images"></i>
            </div>
          </div>
        </div>
        <div class="app-content">
          <div class="app-meta">
            <span class="app-category">Cloud Storage</span>
            <span class="app-status live">Live</span>
          </div>
          <h3>MyGal</h3>
          <p class="app-desc">
            A personal cloud gallery for images, videos, and PDFs with privacy
            controls, dark/light mode, and responsive design.
          </p>
          <div class="app-link">
            View App <i class="fas fa-arrow-right"></i>
          </div>
        </div>
      </a>

      <!-- App 5: Nakano Room -->
      <a
        href="https://nakano-room.vercel.app/"
        target="_blank"
        rel="noopener"
        class="app-card"
      >
        <div class="app-image">
          <img src="/assets/recentProject/NakanoRoom.jpg" alt="Nakano Room" />
          <div class="app-overlay">
            <div class="app-icon">
              <i class="fas fa-comments"></i>
            </div>
          </div>
        </div>
        <div class="app-content">
          <div class="app-meta">
            <span class="app-category">AI Chat</span>
            <span class="app-status live">Live</span>
          </div>
          <h3>Nakano Room</h3>
          <p class="app-desc">
            An AI-powered chat application where you can hang out with the Nakano quintuplets from The Quintessential Quintuplets (五等分の花嫁)!
          </p>
          <div class="app-link">
            View App <i class="fas fa-arrow-right"></i>
          </div>
        </div>
      </a>

      <!-- App 6: PJIMA Perak Dashboard -->
      <a
        href="https://pjima-perak-dashboard.pages.dev/"
        target="_blank"
        rel="noopener"
        class="app-card"
      >
        <div class="app-image">
          <img src="/assets/recentProject/PJIMA-Dashboard.jpg" alt="PJIMA Perak Dashboard" />
          <div class="app-overlay">
            <div class="app-icon">
              <i class="fas fa-chart-bar"></i>
            </div>
          </div>
        </div>
        <div class="app-content">
          <div class="app-meta">
            <span class="app-category">Dashboard</span>
            <span class="app-status live">Live</span>
          </div>
          <h3>PJIMA Perak Dashboard</h3>
          <p class="app-desc">
            A quick and modern dashboard system for PIs and KIPs visualization of UiTM Perak.
          </p>
          <div class="app-link">
            View App <i class="fas fa-arrow-right"></i>
          </div>
        </div>
      </a>

      <!-- App 7: SKSP Portal Rasmi Sekolah -->
      <a
        href="https://sksp.pages.dev/"
        target="_blank"
        rel="noopener"
        class="app-card"
      >
        <div class="app-image">
          <img src="/assets/recentProject/sksp_portal.jpg" alt="SKSP Portal Rasmi Sekolah" />
          <div class="app-overlay">
            <div class="app-icon">
              <i class="fas fa-school"></i>
            </div>
          </div>
        </div>
        <div class="app-content">
          <div class="app-meta">
            <span class="app-category">Web Portal</span>
            <span class="app-status live">Live</span>
          </div>
          <h3>SKSP Portal Rasmi Sekolah</h3>
          <p class="app-desc">
            A modernized website version for Sekolah Kebangsaan Seberang Perak by requested by the ICT teacher.
          </p>
          <div class="app-link">
            View App <i class="fas fa-arrow-right"></i>
          </div>
        </div>
      </a>

      <!-- App 8: JKR Road Construction Tagging Visualizer -->
      <a
        href="https://clarity-roadtag.vercel.app/"
        target="_blank"
        rel="noopener"
        class="app-card"
      >
        <div class="app-image">
          <img src="/assets/recentProject/roadtagvisualizer.jpg" alt="JKR Road Construction Tagging Visualizer" />
          <div class="app-overlay">
            <div class="app-icon">
              <i class="fas fa-map-marked-alt"></i>
            </div>
          </div>
        </div>
        <div class="app-content">
          <div class="app-meta">
            <span class="app-category">Visualization</span>
            <span class="app-status live">Live</span>
          </div>
          <h3>JKR Road Construction Tagging Visualizer</h3>
          <p class="app-desc">
            A modern, interactive map-based visualization tool for tagged locations. Built with Next.js 15, MapTiler SDK, and Cloudinary for image management.
          </p>
          <div class="app-link">
            View App <i class="fas fa-arrow-right"></i>
          </div>
        </div>
      </a>

      <!-- App 9: Complete Guide to Hydra -->
      <a
        href="https://hydra-learn.pages.dev/"
        target="_blank"
        rel="noopener"
        class="app-card"
      >
        <div class="app-image">
          <img src="/assets/recentProject/guide_to_hydra.jpg" alt="Complete Guide to Hydra" />
          <div class="app-overlay">
            <div class="app-icon">
              <i class="fas fa-book"></i>
            </div>
          </div>
        </div>
        <div class="app-content">
          <div class="app-meta">
            <span class="app-category">Guide</span>
            <span class="app-status live">Live</span>
          </div>
          <h3>Complete Guide to Hydra</h3>
          <p class="app-desc">
            Welcome to the comprehensive guide on Hydra, one of the most powerful and widely-used password brute-forcing tools in cybersecurity.
          </p>
          <div class="app-link">
            View App <i class="fas fa-arrow-right"></i>
          </div>
        </div>
      </a>
    </div>
  </div>

  <!-- Font Awesome for icons -->
  <link
    rel="stylesheet"
    href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css"
  />

  <style>
    :root {
      --primary-color: #637cce;
      --secondary-color: #8da7f0;
      --accent-color: #ff7e67;
      --dark-color: #2c3e50;
      --light-color: #f8f9fa;
      --text-color: #333;
      --card-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
      --hover-shadow: 0 15px 35px rgba(0, 0, 0, 0.15);
      --featured-gradient: linear-gradient(135deg, #ffd700 0%, #ffed4e 100%);
    }

    .apps-container {
      max-width: 1400px;
      margin: 0 auto;
      padding: 2rem;
      background: linear-gradient(135deg, #f5f7ff 0%, #e8ecff 100%);
      min-height: 100vh;
      border-radius: 20px;
      box-shadow: 0 5px 20px rgba(0, 0, 0, 0.05);
    }

    .page-header {
      margin-bottom: 3rem;
    }

    .back-link {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      color: var(--primary-color);
      text-decoration: none;
      font-weight: 500;
      margin-bottom: 1.5rem;
      transition: gap 0.3s ease;
    }

    .back-link:hover {
      gap: 0.75rem;
    }

    .header-content {
      text-align: center;
    }

    .header-content h1 {
      font-size: 2.5rem;
      color: var(--dark-color);
      margin-bottom: 0.5rem;
    }

    .header-content p {
      color: #666;
      font-size: 1.1rem;
    }

    .apps-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
      gap: 2rem;
    }

    .app-card {
      background: white;
      border-radius: 16px;
      overflow: hidden;
      box-shadow: var(--card-shadow);
      transition:
        transform 0.3s ease,
        box-shadow 0.3s ease;
      display: flex;
      flex-direction: column;
      text-decoration: none;
      color: inherit;
      border: 2px solid transparent;
      background: linear-gradient(white, white) padding-box,
                  linear-gradient(135deg, #ffd700, #ffed4e) border-box;
    }

    .app-card:hover {
      transform: translateY(-10px);
      box-shadow: var(--hover-shadow);
      border-color: #ffd700;
    }

    .app-image {
      position: relative;
      height: 200px;
      overflow: hidden;
    }

    .app-image img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      transition: transform 0.5s ease;
    }

    .app-card:hover .app-image img {
      transform: scale(1.05);
    }

    .app-overlay {
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      background: linear-gradient(
        to bottom,
        rgba(0, 0, 0, 0.1),
        rgba(0, 0, 0, 0.6)
      );
      display: flex;
      align-items: center;
      justify-content: center;
      opacity: 0;
      transition: opacity 0.3s ease;
    }

    .app-card:hover .app-overlay {
      opacity: 1;
    }

    .app-icon {
      width: 60px;
      height: 60px;
      border-radius: 50%;
      background: rgba(255, 255, 255, 0.9);
      display: flex;
      align-items: center;
      justify-content: center;
      color: var(--primary-color);
      font-size: 1.5rem;
      transform: translateY(20px);
      transition: transform 0.3s ease;
    }

    .app-card:hover .app-icon {
      transform: translateY(0);
    }

    .app-content {
      padding: 1.5rem;
      flex-grow: 1;
      display: flex;
      flex-direction: column;
    }

    .app-meta {
      display: flex;
      justify-content: space-between;
      margin-bottom: 0.75rem;
    }

    .app-category {
      color: var(--primary-color);
      font-weight: 600;
      font-size: 0.9rem;
    }

    .app-status {
      padding: 0.2rem 0.6rem;
      border-radius: 20px;
      font-size: 0.8rem;
      font-weight: 600;
    }

    .app-status.live {
      background-color: rgba(46, 204, 113, 0.15);
      color: #2ecc71;
    }

    .app-status.beta {
      background-color: rgba(241, 196, 15, 0.15);
      color: #f1c40f;
    }

    .app-content h3 {
      font-size: 1.4rem;
      color: var(--dark-color);
      margin-bottom: 0.75rem;
      line-height: 1.3;
    }

    .app-desc {
      color: #666;
      margin-bottom: 1.5rem;
      line-height: 1.5;
      flex-grow: 1;
    }

    .app-link {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      color: var(--primary-color);
      font-weight: 600;
      transition: gap 0.3s ease;
    }

    .app-card:hover .app-link {
      gap: 0.75rem;
    }

    .app-links-row {
      display: flex;
      gap: 0.75rem;
      margin-bottom: 1rem;
    }

    .github-link {
      display: inline-flex;
      align-items: center;
      gap: 0.4rem;
      color: #555;
      text-decoration: none;
      font-size: 0.85rem;
      font-weight: 500;
      padding: 0.3rem 0.7rem;
      background: rgba(0, 0, 0, 0.05);
      border-radius: 6px;
      transition: all 0.2s ease;
    }

    .github-link:hover {
      background: rgba(0, 0, 0, 0.1);
      color: #333;
    }

    /* Responsive adjustments */
    @media (max-width: 768px) {
      .apps-container {
        padding: 1.5rem;
      }

      .header-content h1 {
        font-size: 2rem;
      }

      .apps-grid {
        grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
        gap: 1.5rem;
      }
    }

    @media (max-width: 480px) {
      .header-icon {
        width: 60px;
        height: 60px;
        font-size: 1.5rem;
      }

      .header-content h1 {
        font-size: 1.75rem;
      }

      .apps-grid {
        grid-template-columns: 1fr;
      }

      .app-image {
        height: 180px;
      }
    }
  </style>
</BaseLayout>
