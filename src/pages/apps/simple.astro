---
// src/pages/apps/simple.astro
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout title="Simple Apps 🛠️">
  <div class="apps-container">
    <div class="page-header">
      <a href="/apps" class="back-link">
        <i class="fas fa-arrow-left"></i> Back to Apps
      </a>
      <div class="header-content">
        <h1>Simple Apps</h1>
        <p>Quick utility tools and handy mini-applications</p>
      </div>
    </div>

    <div class="apps-grid">
      <!-- App 1: PDF Merger -->
      <a href="/apps/pdfMerger" rel="noopener" class="app-card">
        <div class="app-image">
          <img src="/assets/apps/pdfMerger.jpg" alt="PDF Merger" />
          <div class="app-overlay">
            <div class="app-icon">
              <i class="fa-solid fa-link"></i>
            </div>
          </div>
        </div>
        <div class="app-content">
          <div class="app-meta">
            <span class="app-category">Productivity</span>
            <span class="app-status live">Live</span>
          </div>
          <h3>Simple PDF Merger</h3>
          <p class="app-desc">A simple and fast pdf merger.</p>
          <div class="app-link">
            View App <i class="fas fa-arrow-right"></i>
          </div>
        </div>
      </a>

      <!-- App 2: Password Generator -->
      <a href="/apps/passwordGen" rel="noopener" class="app-card">
        <div class="app-image">
          <img src="/assets/apps/passwordGen.jpg" alt="Password Generator" />
          <div class="app-overlay">
            <div class="app-icon">
              <i class="fa-solid fa-shield-halved"></i>
            </div>
          </div>
        </div>
        <div class="app-content">
          <div class="app-meta">
            <span class="app-category">Security</span>
            <span class="app-status beta">Beta</span>
          </div>
          <h3>Quick Password Generator</h3>
          <p class="app-desc">
            A quick and easy way to generate your password randomly.
          </p>
          <div class="app-link">
            View App <i class="fas fa-arrow-right"></i>
          </div>
        </div>
      </a>

      <!-- App 3: QR Generator -->
      <a href="/apps/qr-generator" rel="noopener" class="app-card">
        <div class="app-image">
          <img src="/assets/apps/qrGenerator.jpg" alt="QR Generator" />
          <div class="app-overlay">
            <div class="app-icon">
              <i class="fa-solid fa-qrcode"></i>
            </div>
          </div>
        </div>
        <div class="app-content">
          <div class="app-meta">
            <span class="app-category">Multimedia</span>
            <span class="app-status concept">Concept</span>
          </div>
          <h3>QR Generator</h3>
          <p class="app-desc">
            A quick way to create a customized QR Code based on url pasted.
          </p>
          <div class="app-link">
            View App <i class="fas fa-arrow-right"></i>
          </div>
        </div>
      </a>

      <!-- App 4: Color Picker -->
      <a href="/apps/colorPicker" rel="noopener" class="app-card">
        <div class="app-image">
          <div class="app-image-placeholder" style="background: linear-gradient(135deg, #e74c3c, #f39c12, #2ecc71, #3498db, #9b59b6);"></div>
          <div class="app-overlay">
            <div class="app-icon">
              <i class="fa-solid fa-palette"></i>
            </div>
          </div>
        </div>
        <div class="app-content">
          <div class="app-meta">
            <span class="app-category">Utility</span>
            <span class="app-status live">Live</span>
          </div>
          <h3>Color Picker</h3>
          <p class="app-desc">
            Pick a color and copy its values in HEX, RGB, or HSL format instantly.
          </p>
          <div class="app-link">
            View App <i class="fas fa-arrow-right"></i>
          </div>
        </div>
      </a>
    </div>
  </div>

  <!-- Font Awesome for icons -->
  <link
    rel="stylesheet"
    href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css"
  />

  <style>
    :root {
      --primary-color: #637cce;
      --secondary-color: #8da7f0;
      --accent-color: #ff7e67;
      --dark-color: #2c3e50;
      --light-color: #f8f9fa;
      --text-color: #333;
      --card-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
      --hover-shadow: 0 15px 35px rgba(0, 0, 0, 0.15);
      --simple-gradient: linear-gradient(135deg, #74b9ff 0%, #0984e3 100%);
    }

    .apps-container {
      max-width: 1400px;
      margin: 0 auto;
      padding: 2rem;
      background: linear-gradient(135deg, #f5f7ff 0%, #e8ecff 100%);
      min-height: 100vh;
      border-radius: 20px;
      box-shadow: 0 5px 20px rgba(0, 0, 0, 0.05);
    }

    .page-header {
      margin-bottom: 3rem;
    }

    .back-link {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      color: var(--primary-color);
      text-decoration: none;
      font-weight: 500;
      margin-bottom: 1.5rem;
      transition: gap 0.3s ease;
    }

    .back-link:hover {
      gap: 0.75rem;
    }

    .header-content {
      text-align: center;
    }

    .header-content h1 {
      font-size: 2.5rem;
      color: var(--dark-color);
      margin-bottom: 0.5rem;
    }

    .header-content p {
      color: #666;
      font-size: 1.1rem;
    }

    .apps-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
      gap: 2rem;
    }

    .app-card {
      background: white;
      border-radius: 16px;
      overflow: hidden;
      box-shadow: var(--card-shadow);
      transition:
        transform 0.3s ease,
        box-shadow 0.3s ease;
      display: flex;
      flex-direction: column;
      text-decoration: none;
      color: inherit;
      border: 2px solid transparent;
      background: linear-gradient(white, white) padding-box,
                  linear-gradient(135deg, #74b9ff, #0984e3) border-box;
    }

    .app-card:hover {
      transform: translateY(-10px);
      box-shadow: var(--hover-shadow);
      border-color: #74b9ff;
    }

    .app-image {
      position: relative;
      height: 180px;
      overflow: hidden;
    }

    .app-image img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      transition: transform 0.5s ease;
    }

    .app-image-placeholder {
      width: 100%;
      height: 100%;
      transition: transform 0.5s ease;
    }

    .app-card:hover .app-image img {
      transform: scale(1.05);
    }

    .app-card:hover .app-image-placeholder {
      transform: scale(1.05);
    }

    .app-overlay {
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      background: linear-gradient(
        to bottom,
        rgba(0, 0, 0, 0.1),
        rgba(0, 0, 0, 0.6)
      );
      display: flex;
      align-items: center;
      justify-content: center;
      opacity: 0;
      transition: opacity 0.3s ease;
    }

    .app-card:hover .app-overlay {
      opacity: 1;
    }

    .app-icon {
      width: 50px;
      height: 50px;
      border-radius: 50%;
      background: rgba(255, 255, 255, 0.9);
      display: flex;
      align-items: center;
      justify-content: center;
      color: var(--primary-color);
      font-size: 1.25rem;
      transform: translateY(20px);
      transition: transform 0.3s ease;
    }

    .app-card:hover .app-icon {
      transform: translateY(0);
    }

    .app-content {
      padding: 1.25rem;
      flex-grow: 1;
      display: flex;
      flex-direction: column;
    }

    .app-meta {
      display: flex;
      justify-content: space-between;
      margin-bottom: 0.75rem;
    }

    .app-category {
      color: var(--primary-color);
      font-weight: 600;
      font-size: 0.9rem;
    }

    .app-status {
      padding: 0.2rem 0.6rem;
      border-radius: 20px;
      font-size: 0.8rem;
      font-weight: 600;
    }

    .app-status.live {
      background-color: rgba(46, 204, 113, 0.15);
      color: #2ecc71;
    }

    .app-status.beta {
      background-color: rgba(241, 196, 15, 0.15);
      color: #f1c40f;
    }

    .app-status.concept {
      background-color: rgba(155, 89, 182, 0.15);
      color: #9b59b6;
    }

    .app-content h3 {
      font-size: 1.2rem;
      color: var(--dark-color);
      margin-bottom: 0.75rem;
      line-height: 1.3;
    }

    .app-desc {
      color: #666;
      margin-bottom: 1rem;
      line-height: 1.5;
      flex-grow: 1;
      font-size: 0.9rem;
    }

    .app-link {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      color: var(--primary-color);
      font-weight: 600;
      transition: gap 0.3s ease;
    }

    .app-card:hover .app-link {
      gap: 0.75rem;
    }

    /* Responsive adjustments */
    @media (max-width: 768px) {
      .apps-container {
        padding: 1.5rem;
      }

      .header-content h1 {
        font-size: 2rem;
      }

      .apps-grid {
        grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
        gap: 1.5rem;
      }
    }

    @media (max-width: 480px) {
      .header-icon {
        width: 60px;
        height: 60px;
        font-size: 1.5rem;
      }

      .header-content h1 {
        font-size: 1.75rem;
      }

      .apps-grid {
        grid-template-columns: 1fr;
      }

      .app-image {
        height: 160px;
      }
    }
  </style>
</BaseLayout>
