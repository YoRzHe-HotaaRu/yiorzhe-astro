<!-- ChatBot floating widget -->
<div id="chatbot-widget" class="chatbot-widget">
  <button type="button" class="chatbot-toggle" aria-label="Open chat" id="chatbot-toggle">
    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <path d="m3 21 1.9-5.7a8.5 8.5 0 1 1 3.8 3.8z"></path>
    </svg>
  </button>

  <div class="chatbot-panel" id="chatbot-panel">
    <div class="chatbot-header">
      <span class="chatbot-header-title">Chat with Ruby! (≖ᴗ≖✿)</span>
      <button type="button" class="chatbot-close" id="chatbot-close" aria-label="Close chat">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="18" y1="6" x2="6" y2="18"></line>
          <line x1="6" y1="6" x2="18" y2="18"></line>
        </svg>
      </button>
    </div>

    <div class="chatbot-messages" id="chatbot-messages">
      <div class="chatbot-welcome" id="chatbot-welcome">
        <p>Hmph... I'm Ruby, not that I care, but I guess I can answer your questions about Amir. Go ahead, ask already! (≖ᴗ≖✿)</p>
      </div>
      <div class="chatbot-suggestions" id="chatbot-suggestions">
        <button type="button" class="chatbot-chip">What projects has Amir worked on?</button>
        <button type="button" class="chatbot-chip">What are Amir's skills?</button>
        <button type="button" class="chatbot-chip">Tell me about Amir's research</button>
        <button type="button" class="chatbot-chip">What tools does Amir use?</button>
      </div>
    </div>

    <div class="chatbot-input-area">
      <input
        type="text"
        class="chatbot-input"
        id="chatbot-input"
        placeholder="Ask about Amir..."
        autocomplete="off"
      />
      <button type="button" class="chatbot-send" id="chatbot-send" aria-label="Send message">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="22" y1="2" x2="11" y2="13"></line>
          <polygon points="22 2 15 22 11 13 2 9 22 2"></polygon>
        </svg>
      </button>
    </div>
  </div>
</div>

<style is:global>
  .chatbot-widget {
    position: fixed;
    bottom: 24px;
    left: 24px;
    z-index: 130;
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
  }

  .chatbot-toggle {
    width: 52px;
    height: 52px;
    border-radius: 50%;
    border: none;
    background: #637cce;
    color: #fff;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 4px 16px rgba(99, 124, 206, 0.4);
    transition: transform 0.25s ease, box-shadow 0.25s ease, background 0.25s ease;
    pointer-events: auto;
  }

  .chatbot-toggle:hover {
    transform: scale(1.08);
    box-shadow: 0 6px 24px rgba(99, 124, 206, 0.5);
    background: #5570bf;
  }

  .chatbot-toggle.is-hidden {
    transform: scale(0);
    opacity: 0;
    pointer-events: none;
  }

  .chatbot-panel {
    position: absolute;
    bottom: 64px;
    left: 0;
    width: 380px;
    height: 500px;
    background: #fff;
    border-radius: 16px;
    box-shadow: 0 12px 40px rgba(0, 0, 0, 0.15), 0 0 0 1px rgba(99, 124, 206, 0.08);
    display: flex;
    flex-direction: column;
    overflow: hidden;
    transform: scale(0.8) translateY(20px);
    opacity: 0;
    pointer-events: none;
    transition: transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1), opacity 0.25s ease;
    transform-origin: bottom left;
  }

  .chatbot-panel.is-open {
    transform: scale(1) translateY(0);
    opacity: 1;
    pointer-events: auto;
  }

  .chatbot-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 14px 16px;
    background: #637cce;
    color: #fff;
    flex-shrink: 0;
  }

  .chatbot-header-title {
    font-weight: 700;
    font-size: 0.95rem;
    letter-spacing: 0.01em;
  }

  .chatbot-close {
    background: none;
    border: none;
    color: rgba(255, 255, 255, 0.8);
    cursor: pointer;
    padding: 4px;
    border-radius: 6px;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: color 0.2s, background 0.2s;
  }

  .chatbot-close:hover {
    color: #fff;
    background: rgba(255, 255, 255, 0.15);
  }

  .chatbot-messages {
    flex: 1;
    overflow-y: auto;
    padding: 16px;
    display: flex;
    flex-direction: column;
    gap: 10px;
    scroll-behavior: smooth;
  }

  .chatbot-welcome p {
    background: #f0f2f5;
    color: #333;
    padding: 10px 14px;
    border-radius: 16px;
    border-bottom-left-radius: 4px;
    font-size: 0.88rem;
    line-height: 1.5;
    margin: 0;
    max-width: 85%;
  }

  .chatbot-suggestions {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    margin-top: 4px;
  }

  .chatbot-suggestions.is-hidden {
    display: none;
  }

  .chatbot-chip {
    background: #f0f4ff;
    color: #637cce;
    border: 1px solid #d0d9f0;
    padding: 6px 12px;
    border-radius: 20px;
    font-size: 0.78rem;
    font-family: inherit;
    cursor: pointer;
    transition: background 0.2s, color 0.2s;
    white-space: nowrap;
  }

  .chatbot-chip:hover {
    background: #637cce;
    color: #fff;
    border-color: #637cce;
  }

  .chatbot-msg {
    max-width: 85%;
    padding: 10px 14px;
    border-radius: 16px;
    font-size: 0.88rem;
    line-height: 1.5;
    word-wrap: break-word;
    overflow-wrap: break-word;
  }

  .chatbot-msg.user {
    align-self: flex-end;
    background: #637cce;
    color: #fff;
    border-bottom-right-radius: 4px;
  }

  .chatbot-msg.bot {
    align-self: flex-start;
    background: #f0f2f5;
    color: #333;
    border-bottom-left-radius: 4px;
  }

  .chatbot-msg.bot strong {
    font-weight: 700;
  }

  .chatbot-msg.bot em {
    font-style: italic;
  }

  .chatbot-msg.bot ul {
    margin: 4px 0;
    padding-left: 18px;
  }

  .chatbot-msg.bot li {
    margin: 2px 0;
  }

  .chatbot-typing {
    align-self: flex-start;
    display: flex;
    gap: 4px;
    padding: 12px 16px;
    background: #f0f2f5;
    border-radius: 16px;
    border-bottom-left-radius: 4px;
  }

  .chatbot-typing span {
    width: 7px;
    height: 7px;
    background: #999;
    border-radius: 50%;
    animation: chatbot-typing-dot 1.4s infinite ease-in-out;
  }

  .chatbot-typing span:nth-child(2) {
    animation-delay: 0.2s;
  }

  .chatbot-typing span:nth-child(3) {
    animation-delay: 0.4s;
  }

  @keyframes chatbot-typing-dot {
    0%, 80%, 100% { transform: scale(0.6); opacity: 0.4; }
    40% { transform: scale(1); opacity: 1; }
  }

  .chatbot-input-area {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 12px 14px;
    border-top: 1px solid #eee;
    background: #fff;
    flex-shrink: 0;
  }

  .chatbot-input {
    flex: 1;
    border: 1px solid #ddd;
    border-radius: 24px;
    padding: 8px 14px;
    font-size: 0.88rem;
    font-family: inherit;
    outline: none;
    transition: border-color 0.2s;
    background: #f8f9fa;
  }

  .chatbot-input:focus {
    border-color: #637cce;
    background: #fff;
  }

  .chatbot-send {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    border: none;
    background: #637cce;
    color: #fff;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    transition: background 0.2s, transform 0.15s;
  }

  .chatbot-send:hover {
    background: #5570bf;
    transform: scale(1.05);
  }

  .chatbot-send:disabled {
    opacity: 0.5;
    cursor: not-allowed;
    transform: none;
  }

  @media (max-width: 480px) {
    .chatbot-widget {
      bottom: 16px;
      left: 16px;
    }

    .chatbot-panel {
      width: calc(90vw - 32px);
      height: min(500px, calc(70vh));
      bottom: 56px;
    }
  }
</style>

<script is:inline>
  (() => {
    const widget = document.getElementById('chatbot-widget');
    if (!widget || widget.dataset.ready === 'true') return;
    widget.dataset.ready = 'true';

    const toggleBtn = document.getElementById('chatbot-toggle');
    const panel = document.getElementById('chatbot-panel');
    const closeBtn = document.getElementById('chatbot-close');
    const messagesEl = document.getElementById('chatbot-messages');
    const welcomeEl = document.getElementById('chatbot-welcome');
    const suggestionsEl = document.getElementById('chatbot-suggestions');
    const inputEl = document.getElementById('chatbot-input');
    const sendBtn = document.getElementById('chatbot-send');

    if (!toggleBtn || !panel || !closeBtn || !messagesEl || !welcomeEl || !suggestionsEl || !inputEl || !sendBtn) return;

    const messages = [];
    let isOpen = false;
    let isLoading = false;

    function openChat() {
      isOpen = true;
      panel.classList.add('is-open');
      toggleBtn.classList.add('is-hidden');
      inputEl.focus();
    }

    function closeChat() {
      isOpen = false;
      panel.classList.remove('is-open');
      toggleBtn.classList.remove('is-hidden');
    }

    toggleBtn.addEventListener('click', openChat);
    closeBtn.addEventListener('click', closeChat);

    function scrollToBottom() {
      messagesEl.scrollTop = messagesEl.scrollHeight;
    }

    function escapeHtml(str) {
      return str.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
    }

    function markdownToHtml(md) {
      let html = escapeHtml(md);
      // Bold: **text**
      html = html.replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>');
      // Italic: *text*
      html = html.replace(/\*(.+?)\*/g, '<em>$1</em>');
      // Bullet list items: - item
      html = html.replace(/^- (.+)$/gm, '<li>$1</li>');
      // Convert newlines to <br> first
      html = html.replace(/\n/g, '<br>');
      // Wrap consecutive <li> blocks in <ul>
      html = html.replace(/(<br>)*<li>/g, '<li>');
      html = html.replace(/<\/li>(<br>)*/g, '</li>');
      html = html.replace(/(<li>.*?<\/li>)+/g, '<ul>$&</ul>');
      return html;
    }

    function createMsgEl(text, role) {
      const div = document.createElement('div');
      div.className = 'chatbot-msg ' + role;
      if (role === 'bot') {
        div.innerHTML = markdownToHtml(text);
      } else {
        div.textContent = text;
      }
      return div;
    }

    function showTyping() {
      const typing = document.createElement('div');
      typing.className = 'chatbot-typing';
      typing.id = 'chatbot-typing-indicator';
      typing.innerHTML = '<span></span><span></span><span></span>';
      messagesEl.appendChild(typing);
      scrollToBottom();
    }

    function removeTyping() {
      const el = document.getElementById('chatbot-typing-indicator');
      if (el) el.remove();
    }

    function hideSuggestions() {
      suggestionsEl.classList.add('is-hidden');
    }

    async function sendMessage(text) {
      if (isLoading || !text.trim()) return;

      messages.push({ role: 'user', content: text.trim() });
      messagesEl.appendChild(createMsgEl(text.trim(), 'user'));
      hideSuggestions();
      scrollToBottom();

      inputEl.value = '';
      isLoading = true;
      sendBtn.disabled = true;
      showTyping();

      try {
        const res = await fetch('/api/chat', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ messages }),
        });

        const data = await res.json();

        removeTyping();

        if (!res.ok || data.error) {
          const errMsg = data.error || 'Something went wrong. Please try again.';
          messagesEl.appendChild(createMsgEl(errMsg, 'bot'));
          messages.push({ role: 'assistant', content: errMsg });
        } else {
          messagesEl.appendChild(createMsgEl(data.reply, 'bot'));
          messages.push({ role: 'assistant', content: data.reply });
        }
      } catch {
        removeTyping();
        const fallback = 'Could not connect to the server. Please try again later.';
        messagesEl.appendChild(createMsgEl(fallback, 'bot'));
        messages.push({ role: 'assistant', content: fallback });
      }

      isLoading = false;
      sendBtn.disabled = false;
      scrollToBottom();
      inputEl.focus();
    }

    sendBtn.addEventListener('click', () => sendMessage(inputEl.value));

    inputEl.addEventListener('keydown', (e) => {
      if (e.key === 'Enter' && !e.shiftKey) {
        e.preventDefault();
        sendMessage(inputEl.value);
      }
    });

    suggestionsEl.addEventListener('click', (e) => {
      const chip = e.target.closest('.chatbot-chip');
      if (chip) {
        sendMessage(chip.textContent);
      }
    });
  })();
</script>
