---
---

<div id="chatbot-container" class="cb-wrap">
  <button id="chatbot-toggle" class="cb-toggle" aria-label="Open chat">
    <svg class="cb-toggle-icon" viewBox="0 0 32 32" width="30" height="30">
      <g>
        <circle cx="16" cy="17" r="11" fill="white" opacity="0.95"/>
        <circle class="rb-eye" cx="12" cy="15" r="2" fill="#637cce"/>
        <circle class="rb-eye" cx="20" cy="15" r="2" fill="#637cce"/>
        <circle cx="11" cy="14" r="0.7" fill="white"/>
        <circle cx="19" cy="14" r="0.7" fill="white"/>
        <path d="M13 19.5 Q16 22.5 19 19.5" stroke="#e84a5f" stroke-width="1.3" fill="none" stroke-linecap="round"/>
        <path d="M9 18 Q10.5 19.5 12 18" stroke="#ffb3b3" stroke-width="1" fill="none" stroke-linecap="round"/>
        <path d="M20 18 Q21.5 19.5 23 18" stroke="#ffb3b3" stroke-width="1" fill="none" stroke-linecap="round"/>
      </g>
    </svg>
    <span class="cb-badge" id="chatbot-badge"></span>
  </button>

  <div id="chatbot-window" class="cb-win">
    <div class="cb-head">
      <div class="cb-head-info">
        <div class="cb-head-av">
          <svg viewBox="0 0 32 32" width="26" height="26">
            <circle cx="16" cy="17" r="11" fill="rgba(255,255,255,0.25)"/>
            <circle cx="12" cy="15" r="2" fill="white"/>
            <circle cx="20" cy="15" r="2" fill="white"/>
            <path d="M13 19.5 Q16 22.5 19 19.5" stroke="white" stroke-width="1.3" fill="none" stroke-linecap="round"/>
          </svg>
        </div>
        <div>
          <span class="cb-title">Ruby Research</span>
          <span class="cb-status"><span class="cb-dot"></span>Online — let's chat!</span>
        </div>
      </div>
      <button id="chatbot-close" class="cb-close" aria-label="Close">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
      </button>
    </div>

    <div id="chatbot-messages" class="cb-msgs"></div>

    <form id="chatbot-form" class="cb-form">
      <input id="chatbot-input" class="cb-input" type="text" placeholder="Ask me anything about Amir..." autocomplete="off"/>
      <button type="submit" class="cb-send" aria-label="Send">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m22 2-7 20-4-9-9-4Z"/><path d="M22 2 11 13"/></svg>
      </button>
    </form>
  </div>
</div>

<script>
(function(){
  /* ===== Inject CSS via JS (avoids Astro stripping scoped styles) ===== */
  const CSS = `
  .cb-wrap,.cb-wrap *{box-sizing:border-box}
  .cb-wrap{position:fixed;bottom:24px;right:24px;z-index:9999;font-family:'Inter','Helvetica Neue',sans-serif}
  .cb-toggle{width:62px;height:62px;border-radius:50%;border:none;background:linear-gradient(135deg,#637cce,#8da7f0);color:#fff;cursor:pointer;display:flex;align-items:center;justify-content:center;box-shadow:0 4px 22px rgba(99,124,206,.45);transition:.35s cubic-bezier(.175,.885,.32,1.275);animation:cbPulse 3s ease-in-out infinite;position:relative}
  .cb-toggle:hover{transform:scale(1.1) rotate(-5deg);box-shadow:0 8px 32px rgba(99,124,206,.55)}
  .cb-toggle.on{animation:cbSink .4s cubic-bezier(.55,.06,.68,.19) forwards;pointer-events:none}
  @keyframes cbPulse{0%,100%{box-shadow:0 4px 22px rgba(99,124,206,.45)}50%{box-shadow:0 4px 30px rgba(99,124,206,.6),0 0 0 10px rgba(99,124,206,.08)}}
  @keyframes cbSink{0%{opacity:1;transform:scale(1)}100%{opacity:0;transform:scale(.3) rotate(20deg)}}
  .rb-eye{animation:cbBlink 4s ease-in-out infinite}
  @keyframes cbBlink{0%,92%,100%{r:2}95%{r:0.3}}
  .cb-badge{position:absolute;top:-2px;right:-2px;width:14px;height:14px;background:#ff6b6b;border-radius:50%;border:2.5px solid #fff;opacity:0;transform:scale(0);transition:.3s}
  .cb-badge.show{opacity:1;transform:scale(1)}
  .cb-win{position:fixed;bottom:24px;right:24px;width:400px;height:560px;background:#fff;border-radius:20px;box-shadow:0 20px 60px rgba(0,0,0,.2),0 0 0 1px rgba(99,124,206,.08);display:flex;flex-direction:column;overflow:hidden;opacity:0;transform:translateY(30px) scale(.9);pointer-events:none;transition:.4s cubic-bezier(.175,.885,.32,1.275);transform-origin:bottom right}
  .cb-win.open{opacity:1;transform:translateY(0) scale(1);pointer-events:all}
  .cb-head{display:flex;align-items:center;justify-content:space-between;padding:14px 18px;background:linear-gradient(135deg,#5a6fb5,#637cce,#8da7f0);color:#fff;flex-shrink:0}
  .cb-head-info{display:flex;align-items:center;gap:12px}
  .cb-head-av{width:38px;height:38px;background:rgba(255,255,255,.18);border-radius:12px;display:flex;align-items:center;justify-content:center}
  .cb-title{display:block;font-weight:700;font-size:.97rem}
  .cb-status{display:flex;align-items:center;gap:5px;font-size:.72rem;opacity:.85}
  .cb-dot{width:7px;height:7px;background:#4ade80;border-radius:50%;display:inline-block;animation:cbDot 2s ease-in-out infinite}
  @keyframes cbDot{0%,100%{opacity:1;box-shadow:0 0 0 0 rgba(74,222,128,.4)}50%{opacity:.7;box-shadow:0 0 0 4px rgba(74,222,128,0)}}
  .cb-close{background:rgba(255,255,255,.15);border:none;color:#fff;width:32px;height:32px;border-radius:10px;cursor:pointer;display:flex;align-items:center;justify-content:center;transition:.2s}
  .cb-close:hover{background:rgba(255,255,255,.3);transform:rotate(90deg)}
  .cb-msgs{flex:1;overflow-y:auto;overflow-x:hidden;padding:20px 14px;display:flex;flex-direction:column;gap:14px;background:#f4f6fb;scroll-behavior:smooth}
  .cb-msgs::-webkit-scrollbar{width:4px}
  .cb-msgs::-webkit-scrollbar-thumb{background:#cdd5f0;border-radius:10px}
  .cb-msg{display:flex;gap:8px;align-items:flex-end;max-width:88%;animation:cbMsgIn .35s cubic-bezier(.175,.885,.32,1.275);margin:0;padding:0;background:none;border:none}
  .cb-msg.bot{align-self:flex-start}
  .cb-msg.usr{align-self:flex-end;flex-direction:row-reverse}
  @keyframes cbMsgIn{from{opacity:0;transform:translateY(12px) scale(.96)}to{opacity:1;transform:translateY(0) scale(1)}}
  .cb-av{width:30px;height:30px;border-radius:50%;flex-shrink:0;display:flex;align-items:center;justify-content:center;margin:0;padding:0}
  .cb-msg.bot .cb-av{background:linear-gradient(135deg,#637cce,#8da7f0)}
  .cb-msg.usr .cb-av{background:linear-gradient(135deg,#555,#888)}
  .cb-av svg{display:block}
  .cb-col{flex:1;min-width:0;display:flex;flex-direction:column}
  .cb-bub{display:block;padding:11px 15px;border-radius:18px;font-size:.87rem;line-height:1.6;word-break:break-word;overflow-wrap:break-word;white-space:normal;overflow:hidden;margin:0}
  .cb-msg.bot .cb-bub{background:#fff;color:#2d3748;border:1px solid #e8ecf4;border-bottom-left-radius:5px;box-shadow:0 1px 5px rgba(0,0,0,.04)}
  .cb-msg.usr .cb-bub{background:linear-gradient(135deg,#637cce,#7b93de);color:#fff;border-bottom-right-radius:5px;box-shadow:0 2px 8px rgba(99,124,206,.25)}
  .cb-time{font-size:.62rem;color:#a0aec0;margin-top:3px;padding:0 4px}
  .cb-msg.usr .cb-time{text-align:right}
  .cb-msg.bot .cb-bub strong{color:#5a6fb5;font-weight:600}
  .cb-msg.bot .cb-bub em{color:#666}
  .cb-msg.bot .cb-bub ul,.cb-msg.bot .cb-bub ol{margin:6px 0;padding-left:18px}
  .cb-msg.bot .cb-bub li{margin:3px 0}
  .cb-msg.bot .cb-bub code{background:#f0f4ff;padding:2px 6px;border-radius:5px;font-size:.84em;color:#637cce}
  .cb-msg.bot .cb-bub a{color:#637cce;text-decoration:none;font-weight:500;border-bottom:1px dashed #637cce}
  .cb-msg.bot .cb-bub a:hover{border-bottom-style:solid}
  .cb-tw{display:flex;gap:8px;align-items:flex-end;align-self:flex-start;animation:cbMsgIn .35s cubic-bezier(.175,.885,.32,1.275);margin:0;padding:0}
  .cb-tb{background:#fff;border:1px solid #e8ecf4;border-radius:18px;border-bottom-left-radius:5px;padding:14px 20px;box-shadow:0 1px 5px rgba(0,0,0,.04);display:flex;align-items:center;gap:5px;margin:0}
  .cb-td{width:8px;height:8px;border-radius:50%;background:#637cce;animation:cbBnc 1.4s ease-in-out infinite}
  .cb-td:nth-child(2){animation-delay:.15s}
  .cb-td:nth-child(3){animation-delay:.3s}
  @keyframes cbBnc{0%,60%,100%{transform:translateY(0);opacity:.35}30%{transform:translateY(-8px);opacity:1}}
  .cb-form{display:flex;gap:10px;padding:14px 16px;background:#fff;border-top:1px solid #edf0f7;flex-shrink:0}
  .cb-input{flex:1;padding:11px 16px;border:2px solid #e8ecf4;border-radius:14px;font-size:.87rem;outline:none;transition:.25s;font-family:inherit;background:#f8f9fc;color:#2d3748}
  .cb-input::placeholder{color:#a0aec0}
  .cb-input:focus{border-color:#637cce;background:#fff;box-shadow:0 0 0 3px rgba(99,124,206,.1)}
  .cb-send{width:42px;height:42px;border-radius:14px;border:none;background:linear-gradient(135deg,#637cce,#8da7f0);color:#fff;cursor:pointer;display:flex;align-items:center;justify-content:center;transition:.25s cubic-bezier(.175,.885,.32,1.275);flex-shrink:0}
  .cb-send:hover:not(:disabled){transform:scale(1.08);box-shadow:0 4px 16px rgba(99,124,206,.4)}
  .cb-send:active:not(:disabled){transform:scale(.95)}
  .cb-send:disabled{opacity:.4;cursor:not-allowed}
  @media(max-width:480px){
    .cb-wrap{bottom:16px;right:16px}
    .cb-win{width:calc(100vw - 24px);height:calc(100vh - 100px);bottom:12px;right:12px;border-radius:16px}
    .cb-toggle{width:54px;height:54px}
  }`;

  const style = document.createElement('style');
  style.textContent = CSS;
  document.head.appendChild(style);

  /* ===== DOM refs ===== */
  const toggle = document.getElementById('chatbot-toggle');
  const win = document.getElementById('chatbot-window');
  const closeBtn = document.getElementById('chatbot-close');
  const form = document.getElementById('chatbot-form');
  const input = document.getElementById('chatbot-input');
  const msgsEl = document.getElementById('chatbot-messages');
  const sendBtn = form.querySelector('.cb-send');

  let isOpen = false;
  const history = [];

  const now = () => new Date().toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });

  /* ===== Avatars ===== */
  const rubySVG = `<svg viewBox="0 0 32 32" width="18" height="18">
    <circle cx="16" cy="17" r="11" fill="rgba(255,255,255,.3)"/>
    <circle cx="12" cy="15" r="1.8" fill="#fff"/>
    <circle cx="20" cy="15" r="1.8" fill="#fff"/>
    <path d="M13 19.5 Q16 22 19 19.5" stroke="#fff" stroke-width="1.2" fill="none" stroke-linecap="round"/>
  </svg>`;

  const userSVG = `<svg viewBox="0 0 32 32" width="18" height="18">
    <circle cx="16" cy="12" r="5.5" fill="rgba(255,255,255,.3)"/>
    <ellipse cx="16" cy="26" rx="9" ry="7" fill="rgba(255,255,255,.3)"/>
  </svg>`;

  /* ===== Toggle ===== */
  function toggleChat() {
    isOpen = !isOpen;
    if (isOpen) {
      toggle.classList.add('on');
      win.classList.add('open');
      setTimeout(() => { toggle.style.display = 'none'; }, 400);
      setTimeout(() => input.focus(), 450);
    } else {
      toggle.style.display = '';
      toggle.classList.remove('on');
      win.classList.remove('open');
    }
  }
  toggle.addEventListener('click', toggleChat);
  closeBtn.addEventListener('click', () => {
    isOpen = false;
    toggle.style.display = '';
    toggle.classList.remove('on');
    win.classList.remove('open');
  });

  /* ===== Render message ===== */
  function addMsg(text, isUser) {
    const row = document.createElement('div');
    row.className = 'cb-msg ' + (isUser ? 'usr' : 'bot');

    const av = document.createElement('div');
    av.className = 'cb-av';
    av.innerHTML = isUser ? userSVG : rubySVG;

    const col = document.createElement('div');
    col.className = 'cb-col';

    const bub = document.createElement('div');
    bub.className = 'cb-bub';
    bub.innerHTML = isUser ? escHtml(text) : md(text);

    const time = document.createElement('div');
    time.className = 'cb-time';
    time.textContent = now();

    col.appendChild(bub);
    col.appendChild(time);
    row.appendChild(av);
    row.appendChild(col);
    msgsEl.appendChild(row);
    msgsEl.scrollTop = msgsEl.scrollHeight;
  }

  function escHtml(t) {
    const d = document.createElement('div');
    d.textContent = t;
    return d.innerHTML;
  }

  /* ===== Markdown ===== */
  function md(raw) {
    let s = raw.trim();
    s = s.replace(/\[([^\]]+)\]\(([^)]+)\)/g, '<a href="$2" target="_blank" rel="noopener">$1</a>');
    s = s.replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>');
    s = s.replace(/__(.*?)__/g, '<strong>$1</strong>');
    s = s.replace(/(^|[^*])\*([^*]+)\*(?!\*)/g, '$1<em>$2</em>');
    s = s.replace(/`([^`]+)`/g, '<code>$1</code>');
    s = s.replace(/^#{1,3}\s+(.+)$/gm, '<strong>$1</strong>');

    const lines = s.split('\n');
    let out = '', inUl = false, inOl = false;
    const close = () => { if (inUl) { out += '</ul>'; inUl = false; } if (inOl) { out += '</ol>'; inOl = false; } };

    for (const rawLine of lines) {
      const l = rawLine.trim();
      if (/^[-*]\s+/.test(l)) {
        if (inOl) { out += '</ol>'; inOl = false; }
        if (!inUl) { out += '<ul>'; inUl = true; }
        out += '<li>' + l.replace(/^[-*]\s+/, '') + '</li>';
      } else if (/^\d+\.\s+/.test(l)) {
        if (inUl) { out += '</ul>'; inUl = false; }
        if (!inOl) { out += '<ol>'; inOl = true; }
        out += '<li>' + l.replace(/^\d+\.\s+/, '') + '</li>';
      } else {
        close();
        if (l) out += l + '<br>';
      }
    }
    close();
    return out.replace(/<br>$/, '');
  }

  /* ===== Typing ===== */
  function showTyping() {
    rmTyping();
    const w = document.createElement('div');
    w.className = 'cb-tw';
    w.id = 'cb-typing';
    w.innerHTML = '<div class="cb-av">' + rubySVG + '</div><div class="cb-tb"><span class="cb-td"></span><span class="cb-td"></span><span class="cb-td"></span></div>';
    msgsEl.appendChild(w);
    msgsEl.scrollTop = msgsEl.scrollHeight;
  }
  function rmTyping() {
    const el = document.getElementById('cb-typing');
    if (el) { el.style.opacity = '0'; el.style.transition = 'opacity .15s'; setTimeout(() => el.remove(), 160); }
  }

  /* ===== Welcome ===== */
  addMsg("Hey hey! I'm **Ruby**, Amir's cheeky little sidekick. I know pretty much everything about this guy — his projects, research, skills, you name it. Go on, ask me something! ;)", false);

  /* ===== Send ===== */
  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    const text = input.value.trim();
    if (!text) return;
    input.value = '';
    sendBtn.disabled = true;
    addMsg(text, true);
    history.push({ role: 'user', content: text });
    setTimeout(showTyping, 250);

    try {
      const res = await fetch('/api/chat', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ messages: history }),
      });
      const data = await res.json();
      rmTyping();
      setTimeout(() => {
        if (data.reply) {
          addMsg(data.reply, false);
          history.push({ role: 'assistant', content: data.reply });
        } else {
          addMsg('Oops, something glitched. Try again? :(', false);
        }
      }, 150);
    } catch {
      rmTyping();
      setTimeout(() => addMsg('Hmm, connection issue. Give it another shot!', false), 150);
    }
    sendBtn.disabled = false;
    input.focus();
  });
})();
</script>
