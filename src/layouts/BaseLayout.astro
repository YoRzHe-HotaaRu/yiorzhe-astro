---
const title = Astro.props.title || 'YioRzHe-HotaaRu';
import MascotOverlay from '../components/MascotOverlay.astro';
import ChatBot from '../components/ChatBot.astro';
import '../styles/main.scss';
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
   
    <!-- Add Font Awesome -->
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css"
      integrity="sha512-..."
      crossorigin="anonymous"
    />

    <!-- Your styles -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&display=swap" rel="stylesheet">
  </head>
  <body>
    <div class="site-background" aria-hidden="true">
      <video
        class="site-background-video"
        autoplay
        muted
        loop
        playsinline
        preload="none"
        poster="/assets/background/forza_background_poster.jpg"
      >
        <source src="/assets/background/forza_background_optimized.webm" type="video/webm" />
        <source src="/assets/background/forza_background_optimized.mp4" type="video/mp4" />
      </video>
      <div class="site-background-overlay"></div>
    </div>

    <div class="container">
      <header class="header">
        <h1><a href="/" class="logo"><img src="/assets/logo4-transparent.png" alt="YioRzHe-HotaaRu Logo" /></a></h1>
        
        <!-- Hamburger menu button -->
        <button class="nav-toggle" aria-label="toggle navigation">
          <span class="hamburger"></span>
        </button>
        
        <nav class="nav">
          <a href="/apps" class="nav-link">Apps</a>
          <a href="/tools" class="nav-link">Tools</a>
          <a href="/certificates" class="nav-link">Certificates</a>
          <a href="/projects" class="nav-link">Projects</a>
          <a href="/research" class="nav-link">Research</a>
          <a href="/about" class="nav-link">About</a>
          <a href="/contact" class="nav-link">Contact</a>
        </nav>
      </header>

      <main>
        <slot />
      </main>

      <footer>
        © {new Date().getFullYear()} YioRzHe-HotaaRu. Built with Astro.
      </footer>
    </div>

    <MascotOverlay />
    <ChatBot />

    <!-- Add JavaScript for mobile menu toggle -->
    <script>
      document.addEventListener('DOMContentLoaded', () => {
        const navToggle = document.querySelector('.nav-toggle');
        const nav = document.querySelector('.nav');
        const backgroundRoot = document.querySelector('.site-background');
        const backgroundVideo = document.querySelector('.site-background-video');
        const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        const connection = navigator.connection || navigator.mozConnection || navigator.webkitConnection;
        const shouldSaveData = Boolean(connection && connection.saveData);
        const disableBackgroundVideo = prefersReducedMotion || shouldSaveData;
        
        const toggleNav = () => {
          if (navToggle && nav) {
            nav.classList.toggle('nav-open');
            navToggle.classList.toggle('nav-open');
          }
        };
        
        if (navToggle) {
          navToggle.addEventListener('click', toggleNav);
        }

        const enableFallbackPoster = () => {
          if (backgroundRoot) {
            backgroundRoot.classList.add('site-background--fallback');
          }
        };

        const disableFallbackPoster = () => {
          if (backgroundRoot) {
            backgroundRoot.classList.remove('site-background--fallback');
          }
        };

        if (backgroundVideo) {
          backgroundVideo.addEventListener('error', enableFallbackPoster);

          if (disableBackgroundVideo) {
            backgroundVideo.pause();
            backgroundVideo.removeAttribute('autoplay');
            enableFallbackPoster();
          } else {
            disableFallbackPoster();
            backgroundVideo.play()
              .then(() => {
                disableFallbackPoster();
              })
              .catch(() => {
                enableFallbackPoster();
              });
          }

          document.addEventListener('visibilitychange', () => {
            if (document.hidden || disableBackgroundVideo) {
              backgroundVideo.pause();
              return;
            }

            backgroundVideo.play().catch(() => {
              enableFallbackPoster();
            });
          });
        }
      });
    </script>
  </body>
</html>
